            "body": { "mode": "formdata", "formdata": [{ "key": "title", "value": "Flood in Zone A", "type": "text" }, { "key": "description", "value": "River overflow", "type": "text" }, { "key": "type", "value": "flood", "type": "text" }, { "key": "severity", "value": "high", "type": "text" }] },
            "url": "{{baseUrl}}/api/disasters"
          }
